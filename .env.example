# PostgreSQL connection (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/twogis

# 2GIS public reviews API key (from your parser.py)
TWOGIS_REVIEWS_API_KEY=

# Scraping behavior
MAX_CONCURRENT_BRANCHES=5
MAX_BRANCHES_PER_SEARCH=50
REQUEST_TIMEOUT_SECONDS=15
RATE_LIMIT_SLEEP_MIN=1.0
RATE_LIMIT_SLEEP_MAX=2.0

# Default city slug for 2GIS search URLs (e.g., almaty, astana, shymkent)
DEFAULT_CITY_SLUG=almaty
